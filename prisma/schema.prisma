// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user{
  id          String  @id @default(uuid())
  username    String  @unique
  gender      Gender?
  password    String 
  channelname String  @unique
  coverphoto      String?
  profilepicture String?
  subscount    Int     @default(0)
  description  String?  
  uploads      uploads[]
}

enum Gender{
  male 
  female
  others
}

model uploads{
  id          String  @id    @default(uuid())
  userid      String
  user        user    @relation(fields:[userid],references:[id])
  video_url   String   
  status      Videostatus @default(PENDING)
  hls_url     String?
  thumbnail   String
  title       String
  views       Int     @default(0)
  type        Type?
  likes        Int     @default(0)
}
enum Videostatus{
  READY
  FAILED
  PROCESSING
 PENDING  

}

enum Type{
  public
  unlisted
  private
}
